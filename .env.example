# =============================================================================
# CCI / AVCS — environment variables template
# Copy to .env and fill in real values. NEVER commit .env to git.
# =============================================================================

# --- Anthropic (unico provider LLM) -----------------------------------------
ANTHROPIC_API_KEY=sk-ant-...
CCI_LLM_MODEL=claude-sonnet-4-6

# --- MongoDB -----------------------------------------------------------------
MONGODB_URI=mongodb://cci_app:changeme@mongodb:27017/cci_operational?authSource=admin&replicaSet=rs0
MONGODB_AUDIT_URI=mongodb://cci_audit_writer:changeme@mongodb:27017/cci_governance?authSource=admin&replicaSet=rs0
MONGODB_ROOT_USERNAME=root
MONGODB_ROOT_PASSWORD=changeme

# --- Neo4j -------------------------------------------------------------------
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=changeme

# --- Qdrant ------------------------------------------------------------------
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_API_KEY=

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# --- MinIO -------------------------------------------------------------------
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme
MINIO_BUCKET_DOCUMENTS=cci-documents

# --- Observability -----------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://tempo:4317
OTEL_SERVICE_NAME=cci-avcs
PROMETHEUS_PORT=9090

# --- Human-in-the-loop -------------------------------------------------------
HITL_IMPACT_THRESHOLD_EUR=50000
HITL_MOTIVATION_MIN_CHARS=20

# --- Application -------------------------------------------------------------
LOG_LEVEL=INFO
ENVIRONMENT=development
